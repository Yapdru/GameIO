<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Display Name -->
    <key>CFBundleDisplayName</key>
    <string>GameIO MAX ULT</string>

    <!-- Supported Device Orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- iPad Orientations -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Status Bar Configuration -->
    <key>UIStatusBarHidden</key>
    <false/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Allow loading from GitHub and other HTTP sources -->
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsArbitraryLoadsInWebContent</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>github.com</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSExceptionMinimumTLSVersion</key>
                <string>TLSv1.2</string/>
            </dict>
            <key>raw.githubusercontent.com</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Camera Permission (for future features) -->
    <key>NSCameraUsageDescription</key>
    <string>GameIO needs camera access for video chat features</string>

    <!-- Microphone Permission (for future features) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>GameIO needs microphone access for voice chat features</string>

    <!-- Photo Library Permission (for avatar customization) -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>GameIO needs photo library access to customize your avatar</string>

    <!-- Local Network Permission (for multiplayer) -->
    <key>NSBonjourServices</key>
    <array>
        <string>_gameio._tcp</string>
        <string>_gameio-server._tcp</string>
    </array>

    <!-- Health Kit (optional - for activity tracking) -->
    <key>NSHealthShareUsageDescription</key>
    <string>GameIO can track your gaming activity</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>GameIO can record your gaming achievements</string>

    <!-- Apple Sign In -->
    <key>CFBundleTypeRole</key>
    <string>Editor</string>

    <!-- Allow HTTP Localhost (for development) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>GameIO uses local network for multiplayer features</string>

    <!-- Background Modes (optional) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>voip</string>
    </array>

    <!-- Requires Full Screen (iPhone) -->
    <key>UIRequiresFullScreen</key>
    <true/>

    <!-- Minimum iOS Version -->
    <key>MinimumOSVersion</key>
    <string>13.0</string>

    <!-- Supported Document Types -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>GameIO Room Code</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>gameio</string>
            </array>
        </dict>
    </array>

    <!-- Custom URL Scheme -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>com.gameio.maxult</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>gameio</string>
            </array>
        </dict>
    </array>

    <!-- App Groups (for widgets/extensions) -->
    <key>NSApplicationGroups</key>
    <array>
        <string>group.com.gameio.maxult</string>
    </array>

    <!-- Privacy -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>

</dict>
</plist>
